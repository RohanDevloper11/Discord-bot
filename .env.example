# DISCORD_TOKEN: Your Discord Bot Token from the Discord Developer Portal (https://discord.com/developers/applications).
DISCORD_TOKEN="YOUR_DISCORD_BOT_TOKEN"

# DISCORD_CHANNEL: Fallback channel name (e.g. "r1gi-ngl") or exact channel ID where DM messages will be forwarded.
DISCORD_CHANNEL="r1gi-ngl"

# APP_URL: Optional external URL for self-referential dashboard endpoints.
APP_URL="http://localhost:3000"
